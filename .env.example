# 股票选股及风控Agent系统配置

# MySQL数据库配置
MYSQL_ROOT_PASSWORD=stock123
MYSQL_USER=stock
MYSQL_PASSWORD=stock123
MYSQL_PORT=3306

# 应用数据库连接URL（Docker内部使用）
DATABASE_URL=mysql+pymysql://stock:stock123@mysql:3306/stock_analysis?charset=utf8mb4

# 本地开发数据库URL（非Docker环境使用）
# DATABASE_URL=mysql+pymysql://stock:stock123@localhost:3306/stock_analysis?charset=utf8mb4

# 数据抓取Cookie（从浏览器开发者工具复制）
STOCK_COOKIE=your_cookie_here
STOCK_FETCH_TIMEOUT=30
STOCK_FETCH_MAX_RETRIES=3
STOCK_FETCH_RETRY_DELAY=1.0

# AI分析配置（Moonshot API）
# 获取地址：https://platform.moonshot.cn/
MOONSHOT_API_KEY=your_moonshot_api_key_here
MOONSHOT_MODEL=moonshot-v1-8k
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_TEMPERATURE=0.3
MOONSHOT_MAX_TOKENS=2000
MOONSHOT_TIMEOUT=60
MOONSHOT_MAX_RETRIES=2
AI_MAX_DAILY_CALLS=20

# 飞书自定义机器人播报（不要把真实Webhook提交到代码仓库）
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# 日志级别 DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO
TZ=Asia/Shanghai

# Docker 构建 apt 源（国内服务器建议保留默认值）
DEBIAN_MIRROR=https://mirrors.aliyun.com/debian
DEBIAN_SECURITY_MIRROR=https://mirrors.aliyun.com/debian-security

# Docker 构建 pip 源（国内服务器建议保留默认值）
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple
PIP_TRUSTED_HOST=mirrors.aliyun.com

# Wiki/RAG 服务配置（按需启用）
PYTORCH_CPU_INDEX_URL=https://download.pytorch.org/whl/cpu
TORCH_VERSION=2.7.1+cpu
HF_ENDPOINT=https://hf-mirror.com
