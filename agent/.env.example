# 股票选股及风控Agent系统配置

# MySQL数据库配置
MYSQL_ROOT_PASSWORD=stock123
MYSQL_USER=stock
MYSQL_PASSWORD=stock123

# 应用数据库连接URL（Docker内部使用）
DATABASE_URL=mysql+pymysql://stock:stock123@mysql:3306/stock_analysis

# 本地开发数据库URL（非Docker环境使用）
# DATABASE_URL=mysql+pymysql://stock:stock123@localhost:3306/stock_analysis

# 数据抓取Cookie（从浏览器开发者工具复制）
STOCK_COOKIE=your_cookie_here

# AI分析配置（Moonshot API）
# 获取地址：https://platform.moonshot.cn/
MOONSHOT_API_KEY=your_moonshot_api_key_here

# 日志级别 DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO
